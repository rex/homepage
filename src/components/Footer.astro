---
import { BUILD_COMMIT, buildDateShort } from '../lib/build-info';

const date = buildDateShort();
---
<footer class="page-gutter hairline-t mt-24 py-10" data-boot style="--boot-delay: 1200ms;">
  <div class="flex flex-col items-start gap-3 md:flex-row md:items-center md:justify-between">
    <div class="font-mono text-xs tracking-wider text-ink-dim numeric-tabular">
      piercemoore.com · v2.0.0 · build <span class="text-ink-muted">{BUILD_COMMIT}</span> · <span class="text-ink-muted">{date}</span>
    </div>
    <div class="display-italic text-ink-muted text-sm md:text-base">start where you are.</div>
  </div>
</footer>
