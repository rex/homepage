---
import type { HeroContent } from '../lib/content';
import HeroNudge from './HeroNudge.tsx';

export interface Props {
  hero: HeroContent;
}

const { hero } = Astro.props;
const letters = [...hero.name];
---
<section class="hero relative overflow-x-clip pt-12 pb-20 hairline-b" aria-labelledby="hero-name">
  <div class="margin-mark hidden md:block" data-boot style="--boot-delay: 650ms; left: 24px; top: 48px; height: calc(100% - 96px);">
    § <span class="num">01</span> — identity
  </div>

  <div class="page-gutter">
    <div class="font-mono text-xs uppercase tracking-[0.18em] text-ink-muted" data-boot style="--boot-delay: 700ms;">
      {hero.title}
    </div>
  </div>

  <h1
    id="hero-name"
    class="hero-name display-italic text-hero whitespace-nowrap leading-none opsz-display mt-4 page-gutter"
    aria-label="Pierce Moore"
    style="letter-spacing: -0.04em;"
  >
    {letters.map((ch, i) => (
      <span
        class="hero-letter inline-block"
        style={`--letter-i: ${i}; will-change: transform; transition: transform 0.55s cubic-bezier(0.23, 1, 0.32, 1);`}
        aria-hidden="true"
      >{ch === ' ' ? ' ' : ch}</span>
    ))}
  </h1>

  <div class="page-gutter mt-10">
    <div class="hairline-rule" data-boot style="--boot-delay: 820ms;" aria-hidden="true"></div>

    <p class="display-italic text-base md:text-lg text-ink-muted mt-6 leading-snug max-w-md" data-boot style="--boot-delay: 850ms;">
      {hero.tagline}
    </p>

    <div class="mt-8" data-boot style="--boot-delay: 900ms;">
      <span class="pill numeric-tabular">{hero.status}</span>
    </div>

    <p
      class="mt-12 max-w-prose text-base md:text-lg text-ink numeric-oldstyle opsz-body leading-relaxed"
      data-boot
      style="--boot-delay: 950ms;"
    >
      {hero.bio}
    </p>

    <p
      class="mt-8 max-w-prose display-italic text-ink-muted text-base numeric-oldstyle leading-relaxed"
      data-boot
      style="--boot-delay: 1000ms;"
    >
      {hero.signal_sentence}
    </p>
  </div>

  <HeroNudge client:idle />
</section>

<style>
  .hairline-rule {
    width: 320px;
    max-width: 100%;
    height: 1px;
    background: var(--ink-faint);
  }
</style>
