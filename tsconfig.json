{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["astro/client"],
    "allowJs": true,
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "target": "ES2022"
  },
  "include": ["src", ".astro/types.d.ts"],
  "exclude": ["dist", "node_modules", ".astro"]
}
