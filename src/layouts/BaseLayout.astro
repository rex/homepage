---
import '../styles/fonts.css';
import '../styles/globals.css';
import '../styles/boot.css';
import Footer from '../components/Footer.astro';
import ThemeToggle from '../components/ThemeToggle.tsx';
// Header is intentionally NOT imported — file retained per spec but the bar is disabled.
// import Header from '../components/Header.astro';
import SkipToContent from '../components/SkipToContent.astro';
import { BUILD_COMMIT, BUILD_DATE } from '../lib/build-info';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown>;
  bodyClass?: string;
}

const {
  title,
  description,
  canonical,
  ogImage = '/og-image.png',
  jsonLd,
  bodyClass = '',
} = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site ?? 'https://piercemoore.com').toString();
const ogImageUrl = new URL(ogImage, Astro.site ?? 'https://piercemoore.com').toString();
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta name="build-commit" content={BUILD_COMMIT} />
    <meta name="build-date" content={BUILD_DATE} />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0d0d10" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#f4f1ea" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="piercemoore.com" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <link rel="preload" as="font" type="font/woff2" href="/fonts/Fraunces.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/Fraunces-Italic.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/Supreme-Regular.woff2" crossorigin />

    <script is:inline>
      (function () {
        // Theme precedence:
        //   1. Explicit user toggle (localStorage.theme) wins.
        //   2. Otherwise: system says light → light. Anything else
        //      (system says dark, no preference, API absent) → dark.
        function preferredTheme() {
          try {
            var stored = localStorage.getItem('theme');
            if (stored === 'dark' || stored === 'light') return stored;
          } catch (e) {}
          try {
            if (window.matchMedia('(prefers-color-scheme: light)').matches) return 'light';
          } catch (e) {}
          return 'dark';
        }
        document.documentElement.setAttribute('data-theme', preferredTheme());

        // Reactively follow OS theme changes — only when the user has
        // not made an explicit choice. Once they toggle the page's
        // [dark]/[light] control, localStorage takes over and we stop
        // tracking the OS.
        try {
          var mq = window.matchMedia('(prefers-color-scheme: light)');
          var listener = function (e) {
            try {
              if (localStorage.getItem('theme')) return;
            } catch (err) {}
            document.documentElement.setAttribute('data-theme', e.matches ? 'light' : 'dark');
          };
          if (mq.addEventListener) mq.addEventListener('change', listener);
          else if (mq.addListener) mq.addListener(listener);
        } catch (e) {}

        try {
          if (sessionStorage.getItem('boot-played') === 'true') {
            document.documentElement.classList.add('skip-boot');
          } else {
            setTimeout(function () {
              try {
                sessionStorage.setItem('boot-played', 'true');
              } catch (e) {}
            }, 1500);
          }
        } catch (e) {
          document.documentElement.classList.add('skip-boot');
        }
      })();
    </script>

    {jsonLd && <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body class={bodyClass}>
    <SkipToContent />
    <ThemeToggle client:load />
    {/* Header.astro retained but disabled. */}
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
