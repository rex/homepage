---
import type { HeroContent } from '../lib/content';
import HeroNudge from './HeroNudge.tsx';

export interface Props {
  hero: HeroContent;
}

const { hero } = Astro.props;
const letters = [...hero.name];
---
<section class="hero relative page-gutter pt-32 pb-20 overflow-x-clip hairline-b" aria-labelledby="hero-name">
  <div class="margin-mark hidden md:block" data-boot style="--boot-delay: 650ms; left: 24px; top: 96px; height: calc(100% - 192px);">
    § 01 — identity
  </div>

  <h1
    id="hero-name"
    class="hero-name display-italic text-hero whitespace-nowrap leading-none opsz-display"
    aria-label="Pierce Moore"
    style="letter-spacing: -0.035em; margin-left: -0.045em;"
  >
    {letters.map((ch, i) => (
      <span
        class="hero-letter inline-block"
        style={`--letter-i: ${i}; will-change: transform; transition: transform 0.55s cubic-bezier(0.23, 1, 0.32, 1);`}
        aria-hidden="true"
      >{ch === ' ' ? ' ' : ch}</span>
    ))}
  </h1>

  <div class="mt-8 flex flex-wrap items-baseline gap-x-4 gap-y-2" data-boot style="--boot-delay: 720ms;">
    <span class="font-mono text-xs uppercase tracking-[0.16em] text-ink">
      {hero.title}
    </span>
    <span class="text-ink-faint" aria-hidden="true">—</span>
    <span class="display-italic text-ink-muted text-base md:text-lg">{hero.tagline}</span>
  </div>

  <div class="mt-6" data-boot style="--boot-delay: 820ms;">
    <span class="pill numeric-tabular">{hero.status}</span>
  </div>

  <p
    class="mt-14 max-w-prose text-base md:text-lg text-ink numeric-oldstyle opsz-body leading-relaxed"
    data-boot
    style="--boot-delay: 900ms;"
  >
    {hero.bio}
  </p>

  <p
    class="mt-8 max-w-prose display-italic text-ink-muted text-base numeric-oldstyle leading-relaxed"
    data-boot
    style="--boot-delay: 950ms;"
  >
    {hero.signal_sentence}
  </p>

  <HeroNudge client:idle />
</section>
