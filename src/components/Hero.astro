---
import type { HeroContent } from '../lib/content';
// HeroNudge import retained — the cursor-pull effect is parked, not removed.
// Pierce wants to revisit it with a better idea later.
// import HeroNudge from './HeroNudge.tsx';

export interface Props {
  hero: HeroContent;
}

const { hero } = Astro.props;
const letters = [...hero.name];
---
<section class="hero relative overflow-x-clip pt-12 pb-20" aria-labelledby="hero-name">
  <div class="margin-mark hidden md:block" data-boot style="--boot-delay: 650ms;">
    § <span class="num">01</span> — identity
  </div>

  <h1
    id="hero-name"
    class="hero-name display-italic text-hero whitespace-nowrap leading-none opsz-display page-gutter"
    aria-label="Pierce Moore"
    style="letter-spacing: -0.04em;"
  >
    {letters.map((ch, i) => (
      <span
        class="hero-letter inline-block"
        style={`--letter-i: ${i}; will-change: transform; transition: transform 0.55s cubic-bezier(0.23, 1, 0.32, 1);${ch === ' ' ? ' width: 0.25em;' : ''}`}
        aria-hidden="true"
      >{ch === ' ' ? ' ' : ch}</span>
    ))}
  </h1>

  <div class="page-gutter mt-8">
    <div
      class="font-mono text-sm md:text-base uppercase tracking-[0.18em] text-ink whitespace-nowrap"
      data-boot
      style="--boot-delay: 720ms;"
    >
      {hero.title}
    </div>

    <div class="hairline-rule mt-4" data-boot style="--boot-delay: 780ms;" aria-hidden="true"></div>

    <div
      class="display-italic text-2xl md:text-3xl text-ink mt-6 leading-snug"
      data-boot
      style="--boot-delay: 840ms;"
    >
      {hero.tagline}
    </div>

    <div class="mt-8" data-boot style="--boot-delay: 900ms;">
      <span class="pill numeric-tabular">{hero.status}</span>
    </div>

    <p
      class="mt-12 max-w-prose display-italic text-2xl md:text-[1.625rem] text-ink numeric-oldstyle opsz-body leading-snug"
      data-boot
      style="--boot-delay: 960ms;"
    >
      {hero.bio}
    </p>

    <p
      class="mt-8 max-w-prose display-italic text-base md:text-lg text-ink-muted numeric-oldstyle leading-relaxed"
      data-boot
      style="--boot-delay: 1020ms;"
    >
      {hero.signal_sentence}
    </p>
  </div>

  {/* <HeroNudge client:idle />  — disabled per Pierce. Revisit with a better motion idea. */}
</section>

<style>
  .hairline-rule {
    width: 320px;
    max-width: 100%;
    height: 1px;
    background: var(--accent);
  }
</style>
