---
import type { FaqContent } from '../lib/content';

export interface Props {
  faq: FaqContent;
}

const { faq } = Astro.props;
---
<section id="faq" class="page-gutter relative pt-24 pb-16" aria-labelledby="faq-heading">
  <div class="margin-mark hidden md:block" data-boot style="--boot-delay: 650ms;">
    § <span class="num">05</span> — questions
  </div>

  <header class="mb-12 max-w-prose">
    <div class="label-mono mb-3">/ faq</div>
    <h2 id="faq-heading" class="display-roman text-3xl text-ink leading-tight">
      questions recruiters (you?) always ask me.
    </h2>
    {faq.intro && faq.intro.trim().length > 0 && (
      <p class="mt-4 text-base text-ink-muted leading-relaxed">{faq.intro}</p>
    )}
  </header>

  <dl class="faq-grid" data-boot style="--boot-delay: 900ms;">
    {faq.faqs.map((qa) => (
      <>
        <dt class="faq-q display-italic text-ink-muted">{qa.q}</dt>
        <dd class="faq-a text-ink">
          {qa.image && (
            <img
              src={qa.image}
              alt=""
              class="faq-image"
              width="80"
              height="100"
              loading="lazy"
              decoding="async"
            />
          )}
          {qa.a}
        </dd>
      </>
    ))}
  </dl>
</section>

<style>
  .faq-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem 2rem;
  }
  .faq-q {
    font-size: 1.125rem;
    line-height: 1.4;
    margin-top: 1.5rem;
  }
  .faq-q:first-of-type {
    margin-top: 0;
  }
  .faq-a {
    font-size: 1rem;
    line-height: 1.7;
    max-width: 65ch;
    margin-bottom: 1.5rem;
  }
  .faq-image {
    float: left;
    width: 64px;
    height: auto;
    margin: 0.125rem 1rem 0.5rem 0;
    opacity: 0.85;
    /* render the black PNG in current ink color */
    filter: brightness(0) saturate(0) invert(0.94);
  }
  [data-theme='light'] .faq-image {
    filter: brightness(0);
  }
  @media (min-width: 1024px) {
    .faq-grid {
      grid-template-columns: minmax(20ch, 28ch) 1fr;
      column-gap: 4rem;
      row-gap: 2.5rem;
    }
    .faq-q {
      text-align: right;
      margin-top: 0;
      padding-top: 0.125rem;
    }
    .faq-a {
      margin-bottom: 0;
    }
  }
</style>
